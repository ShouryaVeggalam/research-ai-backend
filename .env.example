# ============================================================
# Celestra Research AI — Environment Configuration
# ============================================================

# --- Application ---
APP_NAME="Celestra Research AI"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-super-secret-key-please-rotate-in-production
LOG_LEVEL=INFO
LOG_JSON=false

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- JWT ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
POSTGRES_USER=celestra
POSTGRES_PASSWORD=celestra
POSTGRES_DB=celestra_research
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional full override:
# DATABASE_URL=postgresql+psycopg2://celestra:celestra@localhost:5432/celestra_research

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- AI / LLM (OpenAI compatible) ---
# Leave OPENAI_API_KEY empty to run agents in deterministic heuristic mode.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_ENABLED=false

# --- Bootstrap admin (created on first startup if missing) ---
FIRST_ADMIN_EMAIL=admin@celestra.ai
FIRST_ADMIN_PASSWORD=admin12345
FIRST_ADMIN_NAME=Celestra Admin

# --- CORS ---
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
